# =============================================================================
# VIBRA CONNECT — variables d'environnement (copier vers .env en local)
# Ne jamais committer .env avec de vraies valeurs.
# =============================================================================

# --- Base de données (PostgreSQL, ex. Neon / Supabase / Vercel Postgres) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# --- NextAuth (obligatoire) ---
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- App (recommandé en production) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Cloudinary — upload images (optionnel) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Debug (production : laisser vide) ---
# BUSINESS_CREATE_GUARD_DEBUG=1
